# ── Private Key ────────────────────────────────────────────────
# The deployer wallet private key (without 0x prefix is fine too).
# NEVER commit the real .env file — it is already in .gitignore.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── RPC URLs ───────────────────────────────────────────────────
# Get free endpoints from Alchemy (alchemy.com) or Infura (infura.io).
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Etherscan V2 API Key ──────────────────────────────────────
# One key works for all chains (Sepolia, Base, Mainnet, etc.)
# Get yours at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
